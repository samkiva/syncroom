rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /participants/{userId} {
        allow read, write: if request.auth != null;
      }

      match /messages/{messageId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
